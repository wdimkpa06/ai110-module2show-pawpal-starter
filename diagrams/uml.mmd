classDiagram
    class Owner {
        +str name
        +list~Pet~ pets
        +add_pet(pet: Pet) None
        +get_all_pets() list~Pet~
    }

    class Pet {
        +str name
        +str species
        +list~Task~ tasks
        +add_task(task: Task) None
        +get_tasks() list~Task~
    }

    class Task {
        +str description
        +int duration_minutes
        +str priority
        +str time
        +str pet_name
        +str frequency
        +bool is_complete
        +str due_date
        +mark_complete() None
    }

    class Scheduler {
        +Owner owner
        +int available_minutes
        +get_all_tasks() list~Task~
        +sort_by_priority() list~Task~
        +sort_by_time() list~Task~
        +filter_tasks(pet_name, completed) list~Task~
        +generate_plan() list~Task~
        +explain_plan() str
        +detect_conflicts() list~str~
        +advance_recurring_task(task: Task) Task
        +complete_task(task: Task) Task
    }

    Owner "1" --> "many" Pet : has
    Pet "1" --> "many" Task : has
    Scheduler "1" --> "1" Owner : reads from